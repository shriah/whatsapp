---
import '../styles/global.css';

const siteUrl = 'https://linkdrop.app/';
const title = 'WhatsApp Link Generator | Create a WhatsApp Link with Link Basket';
const description =
	'Create a WhatsApp link with a pre-filled message in your browser. Link Basket builds free wa.me links and QR codes for sellers, catalogs, DMs, and printed material.';
const imageUrl = new URL('/favicon.svg', siteUrl).toString();
const structuredData = [
	{
		'@context': 'https://schema.org',
		'@type': 'SoftwareApplication',
		name: 'Link Basket',
		applicationCategory: 'BusinessApplication',
		operatingSystem: 'Web',
		url: siteUrl,
		description,
		offers: {
			'@type': 'Offer',
			price: '0',
			priceCurrency: 'USD',
		},
		featureList: [
			'Create wa.me WhatsApp links',
			'Add a pre-filled WhatsApp message',
			'Copy or open generated links',
			'Download a client-side QR code PNG',
		],
	},
	{
		'@context': 'https://schema.org',
		'@type': 'WebSite',
		name: 'Link Basket',
		url: siteUrl,
		description,
	},
];
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<link rel="canonical" href={siteUrl} />
		<meta name="generator" content={Astro.generator} />
		<meta name="description" content={description} />
		<meta name="robots" content="index, follow" />
		<meta property="og:type" content="website" />
		<meta property="og:url" content={siteUrl} />
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:image" content={imageUrl} />
		<meta name="twitter:card" content="summary" />
		<meta name="twitter:title" content={title} />
		<meta name="twitter:description" content={description} />
		<meta name="twitter:image" content={imageUrl} />
		<script type="application/ld+json" set:html={JSON.stringify(structuredData)} />
		<title>{title}</title>
	</head>
	<body>
		<slot />
	</body>
</html>

<style>
	html,
	body {
		margin: 0;
		width: 100%;
		min-height: 100%;
	}
</style>
