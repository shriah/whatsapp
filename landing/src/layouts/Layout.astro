---
import '../styles/global.css';
import {
	getLocaleUrl,
	SUPPORTED_LOCALES,
	type Locale,
	type LocaleContent,
} from '@/lib/i18n';

type Props = {
	locale: Locale;
	content: LocaleContent['layout'];
};

const { locale, content } = Astro.props;
const canonicalUrl = getLocaleUrl(locale);
const imageUrl = new URL('/favicon.png', canonicalUrl).toString();
const structuredData = [
	{
		'@context': 'https://schema.org',
		'@type': 'SoftwareApplication',
		name: 'Link Basket',
		applicationCategory: 'BusinessApplication',
		operatingSystem: 'Web',
		url: canonicalUrl,
		description: content.structuredDataDescription,
		offers: {
			'@type': 'Offer',
			price: '0',
			priceCurrency: 'USD',
		},
		featureList: content.featureList,
	},
	{
		'@context': 'https://schema.org',
		'@type': 'WebSite',
		name: 'Link Basket',
		url: canonicalUrl,
		description: content.structuredDataDescription,
	},
];
---

<!doctype html>
<html lang={locale}>
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/png" href="/favicon.png" />
		<link rel="icon" href="/favicon.ico" />
		<link rel="canonical" href={canonicalUrl} />
		<link rel="alternate" hreflang="x-default" href={getLocaleUrl('en')} />
		{SUPPORTED_LOCALES.map((entry) => (
			<link rel="alternate" hreflang={entry} href={getLocaleUrl(entry)} />
		))}
		<meta name="generator" content={Astro.generator} />
		<meta name="description" content={content.description} />
		<meta name="robots" content="index, follow" />
		<meta property="og:type" content="website" />
		<meta property="og:locale" content={locale} />
		<meta property="og:url" content={canonicalUrl} />
		<meta property="og:title" content={content.title} />
		<meta property="og:description" content={content.description} />
		<meta property="og:image" content={imageUrl} />
		<meta name="twitter:card" content="summary" />
		<meta name="twitter:title" content={content.title} />
		<meta name="twitter:description" content={content.description} />
		<meta name="twitter:image" content={imageUrl} />
		<script type="application/ld+json" set:html={JSON.stringify(structuredData)} />
		<title>{content.title}</title>
	</head>
	<body>
		<slot />
	</body>
</html>

<style>
	html,
	body {
		margin: 0;
		width: 100%;
		min-height: 100%;
	}
</style>
