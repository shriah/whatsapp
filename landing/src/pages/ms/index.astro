---
import LinkDropLanding from '../../components/LinkDropLanding';
import Layout from '../../layouts/Layout.astro';
import { getLocaleContent } from '@/lib/i18n';

const locale = 'ms';
const content = getLocaleContent(locale);
---

<Layout locale={locale} content={content.layout}>
	<LinkDropLanding client:load locale={locale} content={content.landing} />
</Layout>
